{
  "entities": {
    "GalleryImage": {
      "title": "GalleryImage",
      "type": "object",
      "description": "Represents a project image in the gallery.",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "alt": { "type": "string" },
        "category": { "type": "string" },
        "path": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "alt", "category"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "type": "object",
      "description": "A message sent via the contact form.",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["name", "email", "message"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/gallery/{imageId}": {
      "schema": { "$ref": "#/entities/GalleryImage" },
      "description": "Public gallery images."
    },
    "/contact-messages/{messageId}": {
      "schema": { "$ref": "#/entities/ContactMessage" },
      "description": "User inquiries."
    },
    "/admins/{uid}": {
      "schema": { "type": "object", "properties": {} },
      "description": "Admin users list."
    }
  }
}