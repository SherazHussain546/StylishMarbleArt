/**
 * Stylish Marble Art - Firestore Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a Database-Backed Access Control (DBAC) model.
 * It provides public read access to the portfolio (gallery) while 
 * limiting modifications to authorized administrators.
 * 
 * Collections:
 * - /admins/{uid}: Role definition. Existence of a UID here defines an admin.
 * - /gallery/{id}: Publicly readable work portfolio.
 * - /contact-messages/{id}: Write-only for users, read-only for admins.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user's UID exists in the /admins collection.
     * NOTE: You must manually add your UID to the /admins collection in the Firebase Console
     * to gain administrative privileges.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    // Admin list management
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console for maximum security
    }

    // Gallery portfolio
    match /gallery/{imageId} {
      // Anyone can view the gallery
      allow read, list: if true;
      // Only admins can upload or delete images
      allow create, update, delete: if isAdmin();
    }

    // Contact form submissions
    match /contact-messages/{messageId} {
      // Anyone can send a message
      allow create: if true;
      // Only admins can read or delete messages
      allow read, list, delete: if isAdmin();
      allow update: if isAdmin();
    }
    
    // Page Content and Services (Placeholder for future dynamic content)
    match /page_content/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}