rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // GALLERY: Completely open for MVP testing to ensure no connection BS
    match /gallery/{imageId} {
      allow read, list, create, update, delete: if true;
    }

    // CONTACT MESSAGES: Open creation, restricted reading
    match /contact-messages/{messageId} {
      allow create: if true;
      allow read, list, delete, update: if isSignedIn();
    }
    
    // ADMINS
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}