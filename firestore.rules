
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY
     * Access is controlled via Firebase Authentication. 
     * Registered administrators have full management access.
     * Force Deployment Sync V6: Reinforcing explicit delete for authenticated admins.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    match /page_content/{pageContentId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /gallery/{imageId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /contact_messages/{messageId} {
      allow create: if true;
      allow get, list, update, delete: if isSignedIn();
    }

    match /contact-messages/{messageId} {
      allow create: if true;
      allow get, list, update, delete: if isSignedIn();
    }
    
    /**
     * @description Digital Memorial Locator. 
     * Public can search and add, only authenticated admins can manage records.
     */
    match /memorials/{memorialId} {
      allow get, list, create: if true;
      allow update, delete: if isSignedIn();
    }

    /**
     * @description Default rules for any other collections.
     */
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
    
    // Deployment trigger comment: Re-synced permissions for administrative management. V6 (Reinforced Delete System)
  }
}
