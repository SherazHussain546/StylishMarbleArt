rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // GALLERY: Public read/list, Authenticated write
    // Using a more robust match pattern for collection-level operations
    match /gallery/{imageId} {
      allow read, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // CONTACT MESSAGES: Anyone can create, only signed-in users can manage
    match /contact-messages/{messageId} {
      allow create: if true;
      allow read, list, delete, update: if isSignedIn();
    }
    
    // ADMINS: Protect this collection
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}