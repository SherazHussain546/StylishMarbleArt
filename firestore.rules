rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // GALLERY: Public read, Authenticated write
    match /gallery/{imageId} {
      allow read, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // CONTACT MESSAGES: Create for everyone, Authenticated read/delete
    match /contact-messages/{messageId} {
      allow create: if true;
      allow read, list, delete, update: if isSignedIn();
    }
    
    // ADMINS: Protect this collection
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}