rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY
     * This ruleset implements a Role-Based Access Control (RBAC) model centered around administrative privileges.
     *
     * DATA STRUCTURE
     * - Public Content: /page_content, /services, /gallery, and /memorials are globally readable to support the public website.
     * - Communication: /contact_messages allows public submissions (write-only for guests) while restricting access to admins.
     * - Memorials: /memorials allows community-driven submissions (creation) while restricting management to admins.
     * - Authorization: /roles_admin is a specialized collection where document existence determines administrative rights.
     */

    // --- Global Helper Functions ---

    /** 
     * @description Checks if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the authenticated user has an entry in the admin roles collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** 
     * @description Combines admin check with a verify-existence check for updates and deletes.
     */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for website content (PageContent entity). Publicly readable, admin-managed.
     */
    match /page_content/{pageContentId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for service offerings (Service entity). Publicly readable, admin-managed.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for the image gallery. Publicly readable, admin-managed.
     */
    match /gallery/{imageId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for contact form submissions. Publicly writable, Admin readable/updatable.
     */
    match /contact_messages/{messageId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }
    
    /**
     * @description Rules for the Digital Memorial Locator. 
     * Allows public reading and community-driven pinning of grave locations.
     * Restricts modification/deletion to administrators.
     */
    match /memorials/{memorialId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Security definitions for the admin role registry.
     */
    match /roles_admin/{userId} {
      // Allows users to check their own admin status; also allows isAdmin() function to perform 'exists' check.
      allow get: if isSignedIn();
      // Listing admins is sensitive and should generally be avoided on the client.
      allow list: if false;
      // Admin privileges should only be granted via Admin SDK, Cloud Functions, or Firebase Console for security.
      allow create, update, delete: if false;
    }
  }
}