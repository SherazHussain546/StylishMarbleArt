rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY
     * This ruleset implements a Role-Based Access Control (RBAC) model centered around administrative privileges.
     *
     * DATA STRUCTURE
     * - Public Content: /page_content, /services, and /gallery_images are globally readable to support the public website.
     * - Communication: /contact_messages allows public submissions (write-only for guests) while restricting access to admins.
     * - Authorization: /roles_admin is a specialized collection where document existence determines administrative rights.
     *
     * KEY DECISIONS
     * - Authorization Independence: Rules avoid complex joins by using the 'exists' check on the roles_admin collection.
     * - Prototyping Flexibility: Data types and non-critical fields are not validated to allow rapid schema iteration.
     * - Structural Segregation: Public and private data are separated into top-level collections to simplify access logic.
     * - Admin-Only Writes: All CMS-style content is protected by an 'isAdmin' check.
     */

    // --- Global Helper Functions ---

    /** 
     * @description Checks if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the authenticated user has an entry in the admin roles collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** 
     * @description Combines admin check with a verify-existence check for updates and deletes.
     */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for website content (PageContent entity). Publicly readable, admin-managed.
     * @path /page_content/{pageContentId}
     * @allow Public user (get) any page content.
     * @deny Non-admin user (update) page content.
     * @principle Public Read with Admin-Only Writes.
     */
    match /page_content/{pageContentId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for service offerings (Service entity). Publicly readable, admin-managed.
     * @path /services/{serviceId}
     * @allow Anonymous visitor (list) services for the landing page.
     * @deny Authenticated non-admin (delete) a service.
     * @principle Public Read with Admin-Only Writes.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for the image gallery (GalleryImage entity). Publicly readable, admin-managed.
     * @path /gallery_images/{galleryImageId}
     * @allow Public user (get) a specific gallery image metadata.
     * @deny Public user (create) a new gallery image entry.
     * @principle Public Read with Admin-Only Writes.
     */
    match /gallery_images/{galleryImageId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for contact form submissions. Publicly writable, Admin readable/updatable.
     * @path /contact_messages/{messageId}
     * @allow Anonymous visitor (create) a message via the contact form.
     * @deny Public user (list) all submitted contact messages.
     * @principle Public Create with Admin-Only Read/Update.
     */
    match /contact_messages/{messageId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Security definitions for the admin role registry.
     * @path /roles_admin/{userId}
     * @allow Signed-in user (get) their own role status to verify UI permissions.
     * @deny Any user (create) an admin document via the client SDK.
     * @principle Restricted registry for identity-based authorization.
     */
    match /roles_admin/{userId} {
      // Allows users to check their own admin status; also allows isAdmin() function to perform 'exists' check.
      allow get: if isSignedIn();
      // Listing admins is sensitive and should generally be avoided on the client.
      allow list: if false;
      // Admin privileges should only be granted via Admin SDK, Cloud Functions, or Firebase Console for security.
      allow create, update, delete: if false;
    }
  }
}