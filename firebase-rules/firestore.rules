rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // GALLERY: Public can read, only signed-in admins can write/delete
    match /gallery/{imageId} {
      allow read: if true;
      allow write, delete: if isSignedIn();
    }
    
    // CONTACT MESSAGES: Anyone can create, admins can read/delete
    match /contact-messages/{messageId} {
      allow create: if true;
      allow read, delete, update: if isSignedIn();
    }

    // MEMORIALS: Public can search and add, only admins can delete/update
    match /memorials/{memorialId} {
      allow read, create: if true;
      allow update, delete: if isSignedIn();
    }
    
    // Default allow for admins on all other paths
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}