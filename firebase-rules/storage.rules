rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public read and write access to the gallery for testing
    // to bypass potential authentication handshake delays in restricted networks
    match /gallery/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
